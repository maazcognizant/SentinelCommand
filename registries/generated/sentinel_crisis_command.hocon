            "name": "Financial_Auditor_Sub_Agent", "function": { "description": "Sub-agent", "parameters": { "type": "object", "properties": { "task": { "type": "string" } }, "required": ["task"] } }, "instructions": "Sub-agent execution.", "allow": { "from_upstream": { "messages": ["Auditor_Agent"] } }
