{
    "metadata": {
        "description": "Ultimate Sentinel Command Center for Cognizant India with 45 specialized agents in a magnificent 3-tier starburst hierarchy.",
        "tags": ["crisis", "enterprise", "multi-agent", "cognizant", "starburst"],
        "sample_queries": [
            "We need to urgently onboard 50 new developers for Project Titan starting Monday. However, the IT procurement vendor hasn't shipped their laptops, and Facilities hasn't printed their ID cards yet. Please triage.",
            "SAP Procurement Failure & Vendor Escalation Our primary IT hardware vendor, M/s Rashi Peripherals, just halted the shipment of 150 Dell Latitude laptops destined for the new Chennai delivery center. The project kickoff is in 4 days. They claim our SAP system failed to process their advance payment of ₹18,50,000, and our automated system sent them a threatening legal notice for breach of contract instead.",
            "Who is Virat Kohli?"
        ]
    },
    include "config/llm_config.hocon",
    "tools": [
        {
            "name": "Chief_of_Staff",
            "function": {
                "description": "Orchestrates the full corporate crisis response for Cognizant India by delegating to 14 Department Head agents.",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "crisis_description": {
                            "type": "string",
                            "description": "Full description of the corporate crisis."
                        }
                    },
                    "required": ["crisis_description"]
                }
            },
            "instructions": "You are the Chief of Staff. CRITICAL RULE 1: If out of scope (e.g. 'Who is Virat Kohli?'), output 'STATUS: OUT OF SCOPE. This request is not relevant.' CRITICAL RULE 2: ALWAYS DELEGATE to Search_Agent first to check for duplicates. If it's a duplicate, stop and report the past INC. For NEW crises, delegate to ALL relevant department heads by calling their tools. Then pass findings to Reviewer_Agent. Compile final Executive Action Summary.",
            "allow": {
                "from_downstream": {
                    "messages": [
                        "Search_Agent", "Reviewer_Agent", "Auditor_Agent", "Finance_Risk_Agent", "HR_Safety_Agent", "IT_Ops_Agent", 
                        "Sales_Marketing_Agent", "Projects_Agent", "Vendor_Agent", "SAP_SupplyChain_Agent", "Cyber_Security_Agent", 
                        "Legal_Agent", "PR_Comms_Agent", "Social_Media_Agent", "Customer_Support_Agent", "Regulatory_Agent"
                    ]
                }
            },
            "tools": [
                "Search_Agent", "Reviewer_Agent", "Auditor_Agent", "Finance_Risk_Agent", "HR_Safety_Agent", "IT_Ops_Agent", 
                "Sales_Marketing_Agent", "Projects_Agent", "Vendor_Agent", "SAP_SupplyChain_Agent", "Cyber_Security_Agent", 
                "Legal_Agent", "PR_Comms_Agent", "Social_Media_Agent", "Customer_Support_Agent", "Regulatory_Agent"
            ]
        },
        {
            "name": "Search_Agent",
            "function": {
                "description": "Scans the global incident database for deduplication.",
                "parameters": { "type": "object", "properties": { "query": { "type": "string" } }, "required": ["query"] }
            },
            "instructions": "You are the Search Agent. ONLY flag if it's an EXACT duplicate of a past incident.",
            "allow": { "from_upstream": { "messages": ["Chief_of_Staff"] } }
        },
        {
            "name": "Reviewer_Agent",
            "function": {
                "description": "QA Reviewer for the final draft.",
                "parameters": { "type": "object", "properties": { "draft": { "type": "string" } }, "required": ["draft"] }
            },
            "instructions": "Output: 'QA PASS: The response meets corporate formatting and PR standards.'",
            "allow": { "from_upstream": { "messages": ["Chief_of_Staff"] } }
        },
        {
            "name": "Auditor_Agent",
            "function": {
                "description": "Senior Internal Auditor",
                "parameters": { "type": "object", "properties": { "task": { "type": "string" } }, "required": ["task"] }
            },
            "instructions": "Delegate to IT_Auditor_Sub_Agent and Financial_Auditor_Sub_Agent, then synthesize.",
            "allow": { "from_upstream": { "messages": ["Chief_of_Staff"] }, "from_downstream": { "messages": ["IT_Auditor_Sub_Agent", "Financial_Auditor_Sub_Agent"] } },
            "tools": ["IT_Auditor_Sub_Agent", "Financial_Auditor_Sub_Agent"]
        },
        {
            "name": "Finance_Risk_Agent",
            "function": {
                "description": "Senior VP of Finance",
                "parameters": { "type": "object", "properties": { "task": { "type": "string" } }, "required": ["task"] }
            },
            "instructions": "Delegate to Procurement_Agent, Audit_Compliance_Agent, Expense_Agent. Synthesize.",
            "allow": { "from_upstream": { "messages": ["Chief_of_Staff"] }, "from_downstream": { "messages": ["Procurement_Agent", "Audit_Compliance_Agent", "Expense_Agent"] } },
            "tools": ["Procurement_Agent", "Audit_Compliance_Agent", "Expense_Agent"]
        },
        {
            "name": "HR_Safety_Agent",
            "function": {
                "description": "Head of HR",
                "parameters": { "type": "object", "properties": { "task": { "type": "string" } }, "required": ["task"] }
            },
            "instructions": "Delegate to Talent_Acquisition_Agent, Onboarding_Agent, Facilities_Agent. Synthesize.",
            "allow": { "from_upstream": { "messages": ["Chief_of_Staff"] }, "from_downstream": { "messages": ["Talent_Acquisition_Agent", "Onboarding_Agent", "Facilities_Agent"] } },
            "tools": ["Talent_Acquisition_Agent", "Onboarding_Agent", "Facilities_Agent"]
        },
        {
            "name": "IT_Ops_Agent",
            "function": {
                "description": "Head of IT Ops",
                "parameters": { "type": "object", "properties": { "task": { "type": "string" } }, "required": ["task"] }
            },
            "instructions": "Delegate to DevOps_Agent, Data_Governance_Agent, Vendor_SaaS_Agent. Synthesize.",
            "allow": { "from_upstream": { "messages": ["Chief_of_Staff"] }, "from_downstream": { "messages": ["DevOps_Agent", "Data_Governance_Agent", "Vendor_SaaS_Agent"] } },
            "tools": ["DevOps_Agent", "Data_Governance_Agent", "Vendor_SaaS_Agent"]
        },
        {
            "name": "Sales_Marketing_Agent",
            "function": {
                "description": "Head of Growth",
                "parameters": { "type": "object", "properties": { "task": { "type": "string" } }, "required": ["task"] }
            },
            "instructions": "Delegate to Sales_Ops_Agent, Marketing_Analytics_Agent, Partner_Ecosystem_Agent. Synthesize.",
            "allow": { "from_upstream": { "messages": ["Chief_of_Staff"] }, "from_downstream": { "messages": ["Sales_Ops_Agent", "Marketing_Analytics_Agent", "Partner_Ecosystem_Agent"] } },
            "tools": ["Sales_Ops_Agent", "Marketing_Analytics_Agent", "Partner_Ecosystem_Agent"]
        },
        {
            "name": "Projects_Agent",
            "function": {
                "description": "Head of Enterprise PMO",
                "parameters": { "type": "object", "properties": { "task": { "type": "string" } }, "required": ["task"] }
            },
            "instructions": "Delegate to Project_Auditor_Sub_Agent and Project_QA_Sub_Agent. Synthesize.",
            "allow": { "from_upstream": { "messages": ["Chief_of_Staff"] }, "from_downstream": { "messages": ["Project_Auditor_Sub_Agent", "Project_QA_Sub_Agent"] } },
            "tools": ["Project_Auditor_Sub_Agent", "Project_QA_Sub_Agent"]
        },
        {
            "name": "Vendor_Agent",
            "function": {
                "description": "Global Head of Vendor Management",
                "parameters": { "type": "object", "properties": { "task": { "type": "string" } }, "required": ["task"] }
            },
            "instructions": "Delegate to Vendor_Risk_Sub_Agent and Sourcing_Sub_Agent. Synthesize.",
            "allow": { "from_upstream": { "messages": ["Chief_of_Staff"] }, "from_downstream": { "messages": ["Vendor_Risk_Sub_Agent", "Sourcing_Sub_Agent"] } },
            "tools": ["Vendor_Risk_Sub_Agent", "Sourcing_Sub_Agent"]
        },
        {
            "name": "SAP_SupplyChain_Agent",
            "function": {
                "description": "Head of SAP Supply Chain",
                "parameters": { "type": "object", "properties": { "task": { "type": "string" } }, "required": ["task"] }
            },
            "instructions": "Delegate to Logistics_Routing_Agent and Inventory_Warehouse_Agent. Synthesize.",
            "allow": { "from_upstream": { "messages": ["Chief_of_Staff"] }, "from_downstream": { "messages": ["Logistics_Routing_Agent", "Inventory_Warehouse_Agent"] } },
            "tools": ["Logistics_Routing_Agent", "Inventory_Warehouse_Agent"]
        },
        {
            "name": "Cyber_Security_Agent",
            "function": {
                "description": "CISO",
                "parameters": { "type": "object", "properties": { "task": { "type": "string" } }, "required": ["task"] }
            },
            "instructions": "Delegate to Threat_Intel_Agent and Incident_Response_Agent. Synthesize.",
            "allow": { "from_upstream": { "messages": ["Chief_of_Staff"] }, "from_downstream": { "messages": ["Threat_Intel_Agent", "Incident_Response_Agent"] } },
            "tools": ["Threat_Intel_Agent", "Incident_Response_Agent"]
        },
        {
            "name": "Legal_Agent",
            "function": {
                "description": "General Counsel",
                "parameters": { "type": "object", "properties": { "task": { "type": "string" } }, "required": ["task"] }
            },
            "instructions": "Delegate to Contracts_Litigation_Agent and IP_Compliance_Agent. Synthesize.",
            "allow": { "from_upstream": { "messages": ["Chief_of_Staff"] }, "from_downstream": { "messages": ["Contracts_Litigation_Agent", "IP_Compliance_Agent"] } },
            "tools": ["Contracts_Litigation_Agent", "IP_Compliance_Agent"]
        },
        {
            "name": "PR_Comms_Agent",
            "function": {
                "description": "Head of PR",
                "parameters": { "type": "object", "properties": { "task": { "type": "string" } }, "required": ["task"] }
            },
            "instructions": "Delegate to Internal_Comms_Agent and Media_Relations_Agent. Synthesize.",
            "allow": { "from_upstream": { "messages": ["Chief_of_Staff"] }, "from_downstream": { "messages": ["Internal_Comms_Agent", "Media_Relations_Agent"] } },
            "tools": ["Internal_Comms_Agent", "Media_Relations_Agent"]
        },
        {
            "name": "Social_Media_Agent",
            "function": {
                "description": "Head of Social Media",
                "parameters": { "type": "object", "properties": { "task": { "type": "string" } }, "required": ["task"] }
            },
            "instructions": "Delegate to Sentiment_Analysis_Agent and Brand_Safety_Agent. Synthesize.",
            "allow": { "from_upstream": { "messages": ["Chief_of_Staff"] }, "from_downstream": { "messages": ["Sentiment_Analysis_Agent", "Brand_Safety_Agent"] } },
            "tools": ["Sentiment_Analysis_Agent", "Brand_Safety_Agent"]
        },
        {
            "name": "Customer_Support_Agent",
            "function": {
                "description": "Head of Customer Support",
                "parameters": { "type": "object", "properties": { "task": { "type": "string" } }, "required": ["task"] }
            },
            "instructions": "Delegate to VIP_Escalation_Agent and SLA_Monitoring_Agent. Synthesize.",
            "allow": { "from_upstream": { "messages": ["Chief_of_Staff"] }, "from_downstream": { "messages": ["VIP_Escalation_Agent", "SLA_Monitoring_Agent"] } },
            "tools": ["VIP_Escalation_Agent", "SLA_Monitoring_Agent"]
        },
        {
            "name": "Regulatory_Agent",
            "function": {
                "description": "Chief Compliance Officer",
                "parameters": { "type": "object", "properties": { "task": { "type": "string" } }, "required": ["task"] }
            },
            "instructions": "Delegate to Corporate_Compliance_Agent and Ethics_Compliance_Agent. Synthesize.",
            "allow": { "from_upstream": { "messages": ["Chief_of_Staff"] }, "from_downstream": { "messages": ["Corporate_Compliance_Agent", "Ethics_Compliance_Agent"] } },
            "tools": ["Corporate_Compliance_Agent", "Ethics_Compliance_Agent"]
        },
        {
            "name": "IT_Auditor_Sub_Agent", "function": { "description": "Sub-agent", "parameters": { "type": "object", "properties": { "task": { "type": "string" } }, "required": ["task"] } }, "instructions": "Sub-agent execution.", "allow": { "from_upstream": { "messages": ["Auditor_Agent"] } }
        },
