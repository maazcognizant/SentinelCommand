{
    # Networks created by `agent_network_designer` are written under registries/generated/.
    # The include keeps them visible to the server without editing this file by hand.
    include "registries/generated/manifest.hocon",

    "music_nerd.hocon": true,
    "movie_buff.hocon": true,
    "agent_network_designer.hocon": true,
    "agent_network_editor.hocon": true,
    "agent_network_query_generator.hocon": true,
    "agent_network_instructions_editor.hocon": true
}
